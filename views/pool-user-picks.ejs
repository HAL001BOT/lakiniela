<!doctype html><html><head><meta charset='utf-8'/><meta name='viewport' content='width=device-width,initial-scale=1'/><title><%= targetMember.name %> picks · <%= pool.name %></title><link rel='icon' href='/img/logo.png'/><link rel='stylesheet' href='/style.css'/></head><body>
<header class='top'><a href='/pools/<%= pool.id %>'>← Back to pool</a><div class='brand'><img class='brand-logo' src='<%= pool.competition_type === "champions_league" ? "/img/champions-league.png" : "/img/logo.png" %>' alt='pool logo'/><h1><%= targetMember.name %> picks</h1></div><span class='badge'><%= pool.name %></span></header>
<main class='grid'>
<section class='card'>
  <h3>Read-only predictions</h3>
  <div class='list'>
    <% rows.forEach(m => { %>
      <div class='match-line'>
        <span class='teams'><img class='team-logo hide-on-error' src='<%= m.home_logo || "" %>' alt=''/> <%= m.home_team %> vs <%= m.away_team %> <img class='team-logo hide-on-error' src='<%= m.away_logo || "" %>' alt=''/></span>
        <small>
          <% if (m.pick) { %>
            Pick: <strong><%= m.pick.pred_home %>-<%= m.pick.pred_away %></strong>
          <% } else { %>
            <span class='muted'>No pick</span>
          <% } %>
          · <%= m.kickoff_local || m.kickoff_at %>
          <% if (m.status === 'finished' && m.home_score != null && m.away_score != null) { %>
            <br/>Final: <strong><%= m.home_score %>-<%= m.away_score %></strong>
            <% if (m.pick) { %>
              <% const pts = Number.isFinite(m.pick.points) ? m.pick.points : (m.pick.points ?? 0); %>
              · Points: <strong class='<%= pts > 0 ? "points-good" : "points-zero" %>'><%= pts %></strong>
            <% } %>
          <% } %>
        </small>
      </div>
    <% }) %>
  </div>
</section>
</main>
<script src='/app.js' defer></script>
</body></html>
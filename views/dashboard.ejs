<!doctype html><html><head><meta charset='utf-8'/><meta name='viewport' content='width=device-width,initial-scale=1'/><title>Dashboard · lakiniela</title><link rel='icon' href='/img/logo.png'/><link rel='stylesheet' href='/style.css?v=20260305mainpoints1'/></head><body>
<header class='top'><div class='brand'><img class='brand-logo' src='/img/logo.png' alt='lakiniela logo'/></div><div class='inline'><a href='/account/password'><button type='button'>Password</button></a><% if (isAdmin) { %><a href='/admin/users'><button type='button'>Admin</button></a><% } %><form method='post' action='/logout'><input type='hidden' name='_csrf' value='<%= csrfToken %>'/><button>Logout</button></form></div></header>
<main class='grid'>
<section class='card'><h2>Welcome, <%= user.name %></h2>
<div class='row'>
<form method='post' action='/pools/create' class='inline'><input type='hidden' name='_csrf' value='<%= csrfToken %>'/><input name='name' placeholder='New pool name'/><select name='competition_type'><option value='liga_mx'>Liga MX</option><option value='champions_league'>Champions League</option></select><button>Create pool</button></form>
<form method='post' action='/pools/join' class='inline'><input type='hidden' name='_csrf' value='<%= csrfToken %>'/><input name='code' placeholder='Join code (e.g. A1B2C3)'/><button>Join</button></form>
</div></section>
<section class='card'><h3>Total Points Dashboard</h3>
<div class='points-dashboard'>
<% pointsDashboard.forEach((u, i) => { %>
  <div class='points-user-card <%= i === 0 ? "points-user-card-top" : "" %>'>
    <div class='points-user-name'><%= u.name %></div>
    <div class='points-user-total'><%= u.points %> pts<% if (i === 0) { %> 👑<% } %></div>
  </div>
<% }) %>
</div>
<% if (!pointsDashboard.length) { %><p class='muted'>No points yet.</p><% } %>
</section>
<section class='card'><h3>Your Pools</h3>
<div class='list'>
<% pools.forEach(p=> { %>
<a class='pool-item' href='/pools/<%= p.id %>'>
  <div class='pool-item-head'><img class='pool-item-logo' src='<%= p.competition_type === "champions_league" ? "/img/champions-league.svg" : "/img/logo.png" %>' alt='pool logo'/><strong><%= p.name %></strong></div>
  <div class='pool-meta-row'>
    <span>Code: <%= p.code %> · <%= p.members %> members · <%= p.competition_type === 'champions_league' ? 'Champions League' : 'Liga MX' %></span>
    <% if (p.pool_finished && p.winner_name) { %>
      <strong class='pool-winner'><%= p.winner_name %> 👑</strong>
    <% } %>
  </div>
</a>
<% }) %>
<% if (!pools.length) { %><p class='muted'>No pools yet. Create one or join with a code.</p><% } %>
</div></section>
<section class='card'><h3>Liga MX Jornada <%= jornadaNumber || 9 %></h3>
<% nextMatches.forEach(m=> { %><div class='match-line'><div class='teams-col'><div class='team-row'><img class='team-logo hide-on-error' src='<%= m.home_logo || "" %>' alt=''/><span><%= m.home_team %></span></div><div class='team-row'><img class='team-logo hide-on-error' src='<%= m.away_logo || "" %>' alt=''/><span><%= m.away_team %></span></div></div><small><%= m.status %> · <%= m.kickoff_local || m.kickoff_at %><% if ((m.status==='live' || m.status==='finished') && m.home_score !== null && m.away_score !== null) { %> · <%= m.home_score %>-<%= m.away_score %><% } %></small></div><% }) %>
<% if (!nextMatches.length) { %><p class='muted'>No scheduled matches available yet. Try sync again in a bit.</p><% } %>
</section>

<section class='card'><h3>Champions League · Next Round <%= championsRoundNumber || 1 %></h3>
<% championsMatches.forEach(m=> { %><div class='match-line'><div class='teams-col'><div class='team-row'><img class='team-logo hide-on-error' src='<%= m.home_logo || "" %>' alt=''/><span><%= m.home_team %></span></div><div class='team-row'><img class='team-logo hide-on-error' src='<%= m.away_logo || "" %>' alt=''/><span><%= m.away_team %></span></div></div><small><%= m.status %> · <%= m.kickoff_local || m.kickoff_at %><% if ((m.status==='live' || m.status==='finished') && m.home_score !== null && m.away_score !== null) { %> · <%= m.home_score %>-<%= m.away_score %><% } %></small></div><% }) %>
<% if (!championsMatches.length) { %><p class='muted'>No Champions League matches available yet. Sync will populate when ESPN posts them.</p><% } %>
</section>
</main><script src='/app.js' defer></script></body></html>
<!doctype html><html><head><meta charset='utf-8'/><meta name='viewport' content='width=device-width,initial-scale=1'/><title>lakiniela Login</title><link rel='icon' href='/img/logo.png'/><link rel='stylesheet' href='/style.css'/></head><body class='auth'>
<div class='card auth-card'><img class='brand-logo big' src='/img/logo.png' alt='lakiniela logo'/><h1>lakiniela</h1><p>Liga MX pools, simple rules, live points.</p>

<!doctype html><html><head><meta charset='utf-8'/><meta name='viewport' content='width=device-width,initial-scale=1'/><title><%= pool.name %> · lakiniela</title><link rel='icon' href='/img/logo.png'/><link rel='stylesheet' href='/style.css?v=20260316share2'/></head><body>
<header class='top'><a href='/dashboard'>← Dashboard</a><div class='brand'><img class='brand-logo' src='<%= pool.competition_type === "champions_league" ? "https://upload.wikimedia.org/wikipedia/en/thumb/b/bf/UEFA_Champions_League_logo_2.svg/240px-UEFA_Champions_League_logo_2.svg.png" : "/img/logo.png" %>' alt='pool logo'/><h1><%= pool.name %></h1></div><span class='badge'>Code: <%= pool.code %></span></header>
<main class='grid two'>
<section class='card' id='standings-card'>
<div class='standings-head'>
  <h3>Standings</h3>
  <button type='button' id='share-standings'>Share snapshot</button>
</div>
<ol class='standings' id='standings-list'>
<% standings.forEach((s, i) => { %>
<li class='<%= i === 0 ? "standing-top" : "" %>' <%= i === 0 ? "style='background:linear-gradient(90deg,rgba(255,215,0,.18),rgba(255,215,0,.04));border:1px solid rgba(255,215,0,.45);border-radius:10px;padding:10px 12px;margin:2px 0 10px;'" : "" %>>
  <span>
    <a href='/pools/<%= pool.id %>/users/<%= s.id %>/picks'><%= s.name %></a>
    <% if (i === 0 && !poolFinished) { %><span class='leader-badge' style='display:inline-flex;align-items:center;gap:4px;margin-left:8px;font-size:.72rem;padding:2px 8px;border-radius:999px;border:1px solid rgba(255,215,0,.55);background:rgba(255,215,0,.12);color:#ffe58a;'>👑 Top</span><% } %>
  </span>
  <strong><%= s.points %> pts<% if (poolFinished && i === 0) { %> <span aria-label='Winner'>👑</span><% } %></strong>
</li>
<% }) %>
</ol></section>
<section class='card'><h3>Predictions · Current / Next Matchday</h3><p class='muted'>3 pts = right result. 5 pts = exact score.</p>
<div class='invite-row'>
  <input class='invite-link' id='invite-link' readonly value='<%= inviteLink %>' />
  <button type='button' id='copy-invite'>Copy invite</button>
</div>
<div class='list'>
<% matches.forEach(m => { const p = predByMatch.get(m.id); const lockMs = new Date(m.kickoff_at).getTime() - (15 * 60 * 1000); const locked = m.status==='finished' || nowMs >= lockMs; %>
<div class='prediction' data-match='<%= m.id %>'>
<div class='prediction-head'>
  <% if ((m.status==='live' || m.status==='finished') && m.home_score !== null && m.away_score !== null) { %>
    <div class='fixture-line'>
      <span class='score-line'>
        <% if (m.status==='finished') { %><span class='final-score-label'>Final score</span><% } %>
        <strong><%= m.home_score %>-<%= m.away_score %></strong>
        <% if (m.status==='live') { %><span class='live-dot' title='Live now'></span><% } %>
      </span>
    </div>
  <% } %>
</div>
<div class='score-inputs'>
  <div class='score-col'>
    <div class='score-input-wrap'>
      <img class='team-logo score-box-logo hide-on-error' src='<%= m.home_logo || "" %>' alt=''/>
      <input type='number' min='0' class='ph' value='<%= p ? p.pred_home : "" %>' <%= locked ? 'disabled' : '' %> />
    </div>
    <label class='team-label team-label-below'><span><%= m.home_team %></span></label>
  </div>
  <div class='score-sep'>-</div>
  <div class='score-col'>
    <div class='score-input-wrap score-input-wrap-right'>
      <img class='team-logo score-box-logo hide-on-error' src='<%= m.away_logo || "" %>' alt=''/>
      <input type='number' min='0' class='pa' value='<%= p ? p.pred_away : "" %>' <%= locked ? 'disabled' : '' %> />
    </div>
    <label class='team-label team-label-right team-label-below'><span><%= m.away_team %></span></label>
  </div>
</div>
<div class='inline'>
<button class='save' <%= locked ? 'disabled' : '' %>><%= locked ? 'Locked' : 'Save' %></button>
<% if (m.status==='live') { %><span class='badge'>Live</span><% } %>
<% if (m.status==='finished') { %><span class='badge'>Final</span><% } %>
<% if (locked && m.status!=='finished') { %><span class='badge'>Locked (-15m)</span><% } %>
</div>
<small class='fixture-meta'><%= m.kickoff_local || m.kickoff_at %></small>
</div>
<% }) %>
</div></section>
</main>
<script src='/app.js' defer></script>
<script src='/vendor/html2canvas.min.js' defer></script>
<script nonce="<%= cspNonce %>">
const csrfToken = '<%= csrfToken %>';
document.querySelectorAll('.prediction .save').forEach(btn=>{btn.onclick=async()=>{const row=btn.closest('.prediction');const id=row.dataset.match;const ph=row.querySelector('.ph').value;const pa=row.querySelector('.pa').value;const r=await fetch(`/pools/<%= pool.id %>/predictions/${id}`,{method:'POST',headers:{'Content-Type':'application/json','x-csrf-token':csrfToken},body:JSON.stringify({pred_home:ph,pred_away:pa})});if(r.ok){btn.textContent='Saved';setTimeout(()=>btn.textContent='Save',900);}else{const j=await r.json().catch(()=>({}));alert(j.error||'Prediction is locked.');}}})

const copyBtn = document.getElementById('copy-invite');
const inviteInput = document.getElementById('invite-link');
if (copyBtn && inviteInput) {
  copyBtn.onclick = async () => {
    try {
      await navigator.clipboard.writeText(inviteInput.value);
      copyBtn.textContent = 'Copied';
      setTimeout(() => (copyBtn.textContent = 'Copy invite'), 1200);
    } catch {
      inviteInput.select();
      document.execCommand('copy');
      copyBtn.textContent = 'Copied';
      setTimeout(() => (copyBtn.textContent = 'Copy invite'), 1200);
    }
  };
}

const shareBtn = document.getElementById('share-standings');
const standingsList = document.getElementById('standings-list');
if (shareBtn && standingsList) {
  shareBtn.onclick = async () => {
    if (!window.html2canvas) {
      alert('Snapshot tool not loaded yet. Please try again.');
      return;
    }

    const original = shareBtn.textContent;
    shareBtn.disabled = true;
    shareBtn.textContent = 'Preparing...';

    try {
      const rows = Array.from(standingsList.querySelectorAll('li')).map((li, i) => {
        const name = li.querySelector('a')?.textContent?.trim() || 'Player';
        const pointsRaw = li.querySelector('strong')?.textContent?.replace('👑', '').trim() || '0 pts';
        return { rank: i + 1, name, points: pointsRaw };
      });

      const shot = document.createElement('div');
      shot.className = 'standings-snapshot';
      shot.innerHTML = `
        <div class="standings-snapshot-head">
          <div>
            <h2>Standings</h2>
            <p><%= pool.name %> · Code <%= pool.code %></p>
          </div>
          <img src="<%= pool.competition_type === 'champions_league' ? 'https://upload.wikimedia.org/wikipedia/en/thumb/b/bf/UEFA_Champions_League_logo_2.svg/240px-UEFA_Champions_League_logo_2.svg.png' : '/img/logo.png' %>" alt="pool" />
        </div>
        <ol>
          ${rows.map((r, i) => `
            <li class="${i === 0 ? 'is-top' : ''}">
              <span class="left"><span class="rank">#${r.rank}</span>${r.name}</span>
              <strong>${r.points}${i === 0 ? ' 👑' : ''}</strong>
            </li>
          `).join('')}
        </ol>
      `;
      document.body.appendChild(shot);

      const canvas = await window.html2canvas(shot, {
        backgroundColor: null,
        scale: Math.min(window.devicePixelRatio || 2, 3),
        useCORS: true,
      });
      shot.remove();

      const blob = await new Promise((resolve) => canvas.toBlob(resolve, 'image/png'));
      if (!blob) throw new Error('snapshot_failed');

      const fileName = `lakiniela-standings-<%= pool.code %>.png`;
      const file = new File([blob], fileName, { type: 'image/png' });

      if (navigator.canShare && navigator.canShare({ files: [file] })) {
        await navigator.share({
          files: [file],
          title: `<%= pool.name %> standings`,
          text: `<%= pool.name %> standings`,
        });
      } else {
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = fileName;
        document.body.appendChild(a);
        a.click();
        a.remove();
        setTimeout(() => URL.revokeObjectURL(url), 1500);
      }

      shareBtn.textContent = 'Shared';
      setTimeout(() => (shareBtn.textContent = original), 1400);
    } catch (e) {
      shareBtn.textContent = original;
      alert('Could not share snapshot right now.');
    } finally {
      shareBtn.disabled = false;
    }
  };
}
</script>
</body></html>
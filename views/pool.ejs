<!doctype html><html><head><meta charset='utf-8'/><meta name='viewport' content='width=device-width,initial-scale=1'/><title><%= pool.name %> · lakiniela</title><link rel='icon' href='/img/logo.jpg'/><link rel='stylesheet' href='/style.css'/></head><body>
<header class='top'><a href='/dashboard'>← Dashboard</a><div class='brand'><img class='brand-logo' src='/img/logo.jpg' alt='lakiniela logo'/><h1><%= pool.name %></h1></div><span class='badge'>Code: <%= pool.code %></span></header>
<main class='grid two'>
<section class='card'><h3>Standings</h3>
<ol class='standings'>
<% standings.forEach(s => { %>
<li><span><%= s.name %></span><strong><%= s.points %> pts</strong></li>
<% }) %>
</ol></section>
<section class='card'><h3>Predictions · Current / Next Matchday</h3><p class='muted'>3 pts = right result. 5 pts = exact score.</p>
<div class='list'>
<% matches.forEach(m => { const p = predByMatch.get(m.id); const lockMs = new Date(m.kickoff_at).getTime() - (15 * 60 * 1000); const locked = m.status==='finished' || nowMs >= lockMs; %>
<div class='prediction' data-match='<%= m.id %>'>
<div class='prediction-head'>
  <% if ((m.status==='live' || m.status==='finished') && m.home_score !== null && m.away_score !== null) { %>
    <div class='fixture-line'>
      <span class='score-line'>
        <strong><%= m.home_score %>-<%= m.away_score %></strong>
        <% if (m.status==='live') { %><span class='live-dot' title='Live now'></span><% } %>
      </span>
    </div>
  <% } %>
</div>
<div class='score-inputs'>
  <div class='score-col'>
    <label class='team-label'><img class='team-logo' src='<%= m.home_logo || "" %>' alt='' onerror="this.style.display='none'"/> <span><%= m.home_team %></span></label>
    <input type='number' min='0' class='ph' value='<%= p ? p.pred_home : "" %>' <%= locked ? 'disabled' : '' %> />
  </div>
  <div class='score-sep'>-</div>
  <div class='score-col'>
    <label class='team-label'><img class='team-logo' src='<%= m.away_logo || "" %>' alt='' onerror="this.style.display='none'"/> <span><%= m.away_team %></span></label>
    <input type='number' min='0' class='pa' value='<%= p ? p.pred_away : "" %>' <%= locked ? 'disabled' : '' %> />
  </div>
</div>
<div class='inline'>
<button class='save' <%= locked ? 'disabled' : '' %>><%= locked ? 'Locked' : 'Save' %></button>
<% if (m.status==='live') { %><span class='badge'>Live</span><% } %>
<% if (m.status==='finished') { %><span class='badge'>Final</span><% } %>
<% if (locked && m.status!=='finished') { %><span class='badge'>Locked (-15m)</span><% } %>
</div>
<small class='fixture-meta'><%= m.kickoff_local || m.kickoff_at %></small>
</div>
<% }) %>
</div></section>
</main>
<script>
document.querySelectorAll('.prediction .save').forEach(btn=>{btn.onclick=async()=>{const row=btn.closest('.prediction');const id=row.dataset.match;const ph=row.querySelector('.ph').value;const pa=row.querySelector('.pa').value;const r=await fetch(`/pools/<%= pool.id %>/predictions/${id}`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({pred_home:ph,pred_away:pa})});if(r.ok){btn.textContent='Saved';setTimeout(()=>btn.textContent='Save',900);}else{const j=await r.json().catch(()=>({}));alert(j.error||'Prediction is locked.');}}})
</script>
</body></html>
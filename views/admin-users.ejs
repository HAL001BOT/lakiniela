<!doctype html><html><head><meta charset='utf-8'/><meta name='viewport' content='width=device-width,initial-scale=1'/><title>Admin · Users</title><link rel='icon' href='/img/logo.png'/><link rel='stylesheet' href='/style.css'/></head><body>
<header class='top'><a href='/dashboard'>← Dashboard</a><div class='brand'><img class='brand-logo' src='/img/logo.png' alt='lakiniela logo'/><h1>Admin · Users</h1></div><span class='badge'>@<%= me.username %></span></header>
<main class='grid'>
<section class='card'><h3>Users</h3>
<div class='list'>
<% users.forEach(u => { %>
  <div class='pool-item'>
    <strong><%= u.name %> (@<%= u.username %>)</strong>
    <span><%= u.email %> · <%= u.pool_count %> pools · <%= u.role %></span>
    <div class='inline'>
      <form method='post' action='/admin/users/<%= u.id %>/role' class='inline'>
        <input type='hidden' name='_csrf' value='<%= csrfToken %>' />
        <select name='role'>
          <option value='user' <%= u.role === 'user' ? 'selected' : '' %>>user</option>
          <option value='admin' <%= u.role === 'admin' ? 'selected' : '' %>>admin</option>
        </select>
        <button>Save role</button>
      </form>
      <% if (u.id !== me.id) { %>
      <form method='post' action='/admin/users/<%= u.id %>/reset-password' class='inline'>
        <input type='hidden' name='_csrf' value='<%= csrfToken %>' />
        <input name='new_password' type='text' placeholder='New password (min 8)' required />
        <button style='background:#0e7490'>Reset password</button>
      </form>
      <form method='post' action='/admin/users/<%= u.id %>/delete' class='confirmable' data-confirm='Delete this user?'>
        <input type='hidden' name='_csrf' value='<%= csrfToken %>' />
        <button style='background:#b4233c'>Delete</button>
      </form>
      <% } %>
    </div>

    <% const memberPools = (poolsByUser && poolsByUser.get(u.id)) || []; %>
    <% if (memberPools.length) { %>
      <div class='list'>
        <% memberPools.forEach(mp => { %>
          <div class='match-line'>
            <span><strong><%= mp.pool_name %></strong> · <small><%= mp.pool_code %></small></span>
            <% if (u.id !== me.id) { %>
            <form method='post' action='/admin/pools/<%= mp.pool_id %>/users/<%= u.id %>/remove' class='confirmable' data-confirm='Remove this user from this pool?'>
              <input type='hidden' name='_csrf' value='<%= csrfToken %>' />
              <button style='background:#b45309'>Remove from pool</button>
            </form>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
<% }) %>
</div>
</section>
</main>
<script src='/app.js' defer></script>
</body></html>
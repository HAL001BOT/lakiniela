<!doctype html><html><head><meta charset='utf-8'/><meta name='viewport' content='width=device-width,initial-scale=1'/><title>LaKiniela Register</title><link rel='icon' href='/img/logo.jpg'/><link rel='stylesheet' href='/style.css'/></head><body class='auth'>
<div class='card auth-card'><img class='brand-logo big' src='/img/logo.jpg' alt='LaKiniela logo'/><h1>Create account</h1>
<% if (error) { %><p class='error'><%= error %></p><% } %>
<form method='post' action='/register'>
<input name='name' placeholder='Your name'/><input name='email' placeholder='Email'/><input type='password' name='password' placeholder='Password'/><button>Create account</button>
</form><a href='/login'>I already have an account</a></div></body></html>